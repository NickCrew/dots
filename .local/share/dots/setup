#!/usr/bin/env bash

proto=git
remote_url=git@github.com:

if [[ ! -z $1 ]]; then
    proto=$1
    if [[ $proto == "https" ]]; then
        remote_url=https://github.com/
    else
        echo "Invalid git protocol: ${proto}"
        echo "USAGE: setup [git|https]"
        exit 1
    fi
fi

mkdir -p ~/.cache/nvim/undo
mkdir -p ~/.cache/zsh

dots config status.showUntrackedFiles no

git clone ${remote_url}NickCrew/zsh-config ~/.zsh
git clone ${remote_url}NickCrew/nvim-config ~/.config/nvim
git clone ${remote_url}NickCrew/tmux-config ~/.tmux.conf.d

echo "Additional setup scripts can be found under ~/.local/share/dots/scripts"
