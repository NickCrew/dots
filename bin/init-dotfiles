#!/usr/bin/env bash

git clone --bare git@github.com:NickCrew/dots.git $HOME/.dots
function dots {
   git --git-dir=$HOME/.dots/ --work-tree=$HOME $@
}
mkdir -p .dots-backup
dots checkout
if [ $? = 0 ]; then
  echo "Checked out dotfiles from git@github.com:NickCrew/dots.git";
  else
    echo "Moving existing dotfiles to ~/.dots-backup";
    dots checkout 2>&1 | egrep "\s+\." | awk {'print $1'} | xargs -I{} mv {} .dots-backup/{}
fi;
dots checkout
dots config status.showUntrackedFiles no
