#!/usr/bin/env zsh

# {{{ Functions

function install_common_pkgs () {
    if ! command -v >/dev/null; then
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    # Install dev workstation packages
    brew install \
        asdf \
        autoconf \
        automake \
        autossh \
        byacc \
        bzip2 \
        coreutils \
        diff-so-fancy
        gawk \
        gcc \
        gnu-sed \
        gnupg \
        howdoi \
        libevent \
        macvim \
        make \
        pkg-config \
        ranger \
        tldr \
        yamllint \
        zsh 

    # Neovim
    brew install --HEAD universal-ctags/universal-ctags/universal-ctags
    brew install --HEAD neovim

    # Nerdfonts
    brew tap homebrew/cask-fonts
    brew install --cask \
        font-sauce-code-pro-nerd-font \
        font-fira-code-nerd-font

    brew install gh
    gh extension install gennaro-tedesco/gh-f
}


function install_python_pkgs () {
    brew install pyenv pyenv-virtualenv pyenv-virtualenvwrapper pipx
    pip install --user pynvim                                       
    pip install --user 'python-lsp-server[all]' pylsp-mypy pyls-isort      

    pipx install \
        pylint \
        ansible \
        ansible-lint \
        yapf \
        autopep8 

}


function install_cargo_pkgs () {
    if ! command -v cargo >/dev/null; then
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
    fi
    source ~/.cargo/env

    cargo install \
        zoxide \
        mcfly \
        ripgrep \
        fd-find \
        broot \
        bat \
        exa
}


function install_lua_pkgs () {
    brew install luarocks
    luarocks install --server=https://luarocks.org/dev luaformatter
    luarocks install fennel
}


function install_nodejs_pkgs () {

    brew install nodejs
    npm install -g \
        yarn \
        vim-language-server \
        bash-language-server \
        vscode-json-languageserver \
        yaml-language-server \
        prettier \
        pyright \
        ansible-language-server \
        dockerfile-language-server-nodejs 



}

# }}}

DOTS_INSTALL_PY_PKGS=${DOTS_INSTALL_PY_PKGS:-false}
DOTS_INSTALL_COMMON_PKGS=${DOTS_INSTALL_COMMON_PKGS:-true}
DOTS_INSTALL_NODE_PKGS=${DOTS_INSTALL_NODE_PKGS:-true}
DOTS_INSTALL_RUST_PKGS=${DOTS_INSTALL_RUST_PKGS:-true}
DOTS_INSTALL_LUA_PKGS=${DOTS_INSTALL_LUA_PKGS:-true}

[[ $DOTS_INSTALL_COMMON_PKGS ]] && install_common_pkgs
[[ $DOTS_INSTALL_NODE_PKGS ]] && install_nodejs_pkgs
[[ $DOTS_INSTALL_RUST_PKGS ]] && install_cargo_pkgs
[[ $DOTS_INSTALL_LUA_PKGS ]] && install_lua_pkgs
[[ $DOTS_INSTALL_PY_PKGS ]] && install_python_pkgs
